# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Your Discord account token (required)
DISCORD_TOKEN=paste_your_token_here

# Giphy API key — get a free one at https://developers.giphy.com
# Required for the giphy command, optional otherwise
GIPHY_API_KEY=paste_your_giphy_key_here

# OpenRouter API key — for AI-powered fuzzy gif matching in the post command
# Only needed when running outside Replit (e.g. Termux)
# Get a free account at https://openrouter.ai
OPENROUTER_API_KEY=paste_your_openrouter_key_here
